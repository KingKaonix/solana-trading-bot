# ─── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Solana RPC ───────────────────────────────────────────────
SOLANA_RPC_URL=
# Recommended: use a private RPC for speed (Helius, QuickNode, Triton)
#SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# ─── Jupiter Aggregator (swaps) ───────────────────────────────
JUPITER_API_URL=https://quote-api.jup.ag/v6

# ─── Pump.fun / Raydium (sniper) ──────────────────────────────
PUMPFUN_WS_URL=wss://pumpportal.fun/api/data

# ─── Redis (sessions & state) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Optional: Ethereum plugin ────────────────────────────────
# ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
# UNISWAP_API_URL=https://api.uniswap.org/v2

# ─── Optional: BSC plugin ─────────────────────────────────────
# BSC_RPC_URL=https://bsc-dataseed.binance.org

# ─── Optional: DexScreener (trends) ──────────────────────────
DEXSCREENER_API=https://api.dexscreener.com/latest

# ─── Security ─────────────────────────────────────────────────
# Encrypt private keys at rest — set a strong secret
WALLET_ENCRYPTION_SECRET=joemmulik

# ─── Bot Config ───────────────────────────────────────────────
DEFAULT_SLIPPAGE_BPS=100        # .5%
DEFAULT_PRIORITY_FEE=50000      # lamports
MAX_BUY_SOL=1.0                 # safety cap per trade
BOT_FEE_BPS=10                  # 0.1% revenue fee (optional)
